# Supabase — crie um projeto gratuito em https://supabase.com
# e copie os valores de Project Settings → API.
# Sem estas chaves o app roda em "modo prévia" (sem login nem dados).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Somente servidor (NUNCA exponha com NEXT_PUBLIC_): usada para convidar
# pessoas (criação de usuários) e para os scripts de scripts/.
SUPABASE_SERVICE_ROLE_KEY=
